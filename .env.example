APP_ENV=development
USE_DUMMY_DATA=false
LINEAGE_DEBUG_RERANK=true
CORS_ALLOWED_ORIGINS=

# Local/LAN default: chroma
# Vercel default: readonly_json
LINEAGE_MEMORY_BACKEND=chroma
LINEAGE_JSON_MEMORY_DIR=./memory_data
EPISODE_SCRIPTS_DIR=./episode_scripts

CHROMA_MODE=embedded
CHROMA_PERSIST_PATH=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=friendsos_memory
CHROMA_MAIN_SCRIPT_COLLECTION_NAME=friendsos_main_script

FRIENDSOS_RESPONSE_DELAY_MS=6800

DIALOGUE_PROVIDER=gemini
SUMMARY_PROVIDER=gemini
ARC_SUMMARY_PROVIDER=gemini
ASK_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_DIALOGUE_MODEL=gemini-3.1-flash-lite-preview
GEMINI_DIALOGUE_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARY_MODEL=gemini-3-flash-preview
GEMINI_ARC_SUMMARY_MODEL=gemini-3-flash-preview
GEMINI_ARC_SUMMARY_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_ARC_SUMMARY_MODEL_POOL=gemini-3.1-flash-lite-preview,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3-flash-preview
GEMINI_ARC_SUMMARY_ROTATION_SECONDS=15
GEMINI_ASK_MODEL=gemini-2.5-flash-lite
GEMINI_ASK_FALLBACK_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=
GROQ_DIALOGUE_MODEL=llama-3.1-8b-instant
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile
GROQ_ARC_SUMMARY_MODEL=llama-3.3-70b-versatile
GROQ_ASK_MODEL=llama-3.1-8b-instant
GROQ_MAX_RETRIES=2

NODE_RECOMMENDED_VERSION=22.12.0
